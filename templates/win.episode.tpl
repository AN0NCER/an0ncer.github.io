<span class="windowed window-episode hide">
    <span class="hide-window"></span>
    <span class="window-content content-episode scroll-none hide">
        <span class="content-wrapper">
            <div class="wrapper">
                <div class="window-bar episode-bar">
                    <div class="window-title">Эпизоды</div>
                    <div class="window-close">
                        <div class="ticon i-xmark"></div>
                    </div>
                </div>

                <div class="episode-list-wrapper">
                    <div class="grid-wrapper-list scroll-none">
                        <div class="episode-grid-list"></div>
                    </div>
                </div>
            </div>
            <span class="episode-list-search">
                <div class="episode-search-wrapper" id="episode-jump-bar">
                    <input type="number" placeholder="Номер эпизода" step="1" inputmode="numeric">
                    <div class="btn btn-new" id="go-episode">
                        <div class="ticon i-play"></div>
                    </div>
                </div>
            </span>
        </span>
    </span>
